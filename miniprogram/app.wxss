page {
  background: #f5f2ea;
  color: #222;
  font-size: 28rpx;
}

.page {
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(38, 70, 83, 0.08);
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #264653;
  margin-bottom: 12rpx;
}

.section-text {
  color: #5f5a55;
  line-height: 1.6;
}

.primary-button {
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 18rpx;
  background: #264653;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.primary-button[disabled] {
  opacity: 0.55;
}

.secondary-button {
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 16rpx;
  background: #e76f51;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.ghost-button {
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 16rpx;
  background: #f1e4d4;
  color: #7a4a27;
  font-size: 26rpx;
  font-weight: 700;
  padding: 0 20rpx;
}

.empty-text {
  color: #8b847d;
  padding: 16rpx 0;
}

.message {
  margin-top: 16rpx;
  color: #7a4a27;
}
